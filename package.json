{
  "name": "cladd-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run codegen && next dev",
    "build": "npm run codegen && next build",
    "start": "next start",
    "worker:dev": "next build && wrangler dev",
    "cf-typegen": "wrangler types ./src/worker/worker-configuration.d.ts",
    "check-types": "tsc --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "codegen": "npm run extract-props && npm run extract-example-source",
    "extract-props": "node scripts/extract-props.mjs",
    "extract-example-source": "node scripts/extract-example-source.mjs"
  },
  "dependencies": {
    "@cladd-ui/react": "^0.0.30",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.4",
    "clsx": "^2.1.1",
    "hono": "^4.12.16",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-pretty-code": "^0.14.3",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.47.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.87.0"
  }
}
